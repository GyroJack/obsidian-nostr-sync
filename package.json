{
  "name": "obsidian-nostr-sync",
  "version": "1.0.1",
  "description": "Encrypted Obsidian vault sync via Nostr relays (NIP-44)",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -noEmit -skipLibCheck"
  },
  "keywords": [
    "obsidian",
    "nostr",
    "sync",
    "encrypted",
    "nip-44"
  ],
  "license": "MIT",
  "dependencies": {
    "nostr-tools": "^2.19.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.25.0",
    "obsidian": "^1.7.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
